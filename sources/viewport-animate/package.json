{
  "name": "viewport-animate",
  "version": "0.0.0",
  "description": "Easy and performant API for applying CSS animations when elements are scrolled into the viewport.",
  "type": "module",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts ",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "test:dev": "vitest",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "release": "np --no-yarn",
    "release:preview": "np --no-yarn --preview"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@vitest/coverage-v8": "^4.0.18",
    "publint": "^0.3.18",
    "tsdown": "0.21.0-beta.2",
    "vitest": "^4.0.18",
    "np": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=14.17"
  },
  "author": {
    "name": "dystopiandev",
    "email": "me@dystopian.dev",
    "url": "https://dystopian.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dystopiandev/viewport-animate.js.git"
  },
  "license": "MIT",
  "keywords": []
}
